<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- 2. 方块刚体 -->
    <body name="box_body" pos="0.5 0.0 0.02">
      <freejoint name="cube_joint"/>
      <!-- 惯性属性：定义质量和转动惯量 -->
      <!-- fullinertia="ixx iyy izz ixy ixz iyz" -->
      <!-- <inertial pos="0 0 0" mass="0.2" diaginertia="0.1 0.1 0.1"/> -->

      <!-- 几何形状：定义外观和碰撞形状 -->
      <!-- size="x半长 y半长 z半长" -->
      <geom name="box_geom" type="box" size="0.02 0.02 0.02" rgba="1 0 0 1" condim="4" friction="1.0 0.005 0.0001"/>

      <!-- 自由关节：允许方块在空间中自由移动和旋转 -->
      <!-- <joint name="box_joint" type="free"/> -->
    </body>
  </worldbody>
</mujoco>
